# NeoShare — Firebase Configuration
# These values come from your Firebase project settings.
# For this submission, firebase_options.dart and google-services.json
# are included in the repo so the reviewer can run the app directly
# against the live Firebase project without any setup.
#
# If you want to run against your own Firebase project:
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Add an Android app with package name: com.example.neoshare
# 3. Download google-services.json → android/app/google-services.json
# 4. Run: flutterfire configure
#    This regenerates lib/firebase_options.dart automatically.
# 5. Deploy Cloud Functions: cd functions && npm install && firebase deploy --only functions
# 6. Deploy Firestore rules: firebase deploy --only firestore:rules
# 7. Create Firestore index: firebase deploy --only firestore:indexes

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_APP_ID=your-app-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
