<?xml version="1.0" encoding="utf-8"?>
<!--
  Explicitly enforces TLS-only traffic for NeoShare.
  No cleartext (HTTP) connections are permitted to any domain.
  All Firebase, Firestore, Storage, and FCM traffic uses HTTPS/TLS 1.2+.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
